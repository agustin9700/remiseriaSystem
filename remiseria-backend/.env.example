# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/remiseria

# JWT — generar con: openssl rand -hex 64
JWT_SECRET=cambia_esto_por_un_secret_seguro_minimo_64_chars
JWT_REFRESH_SECRET=cambia_esto_por_otro_secret_distinto_minimo_64_chars

# Puerto del servidor (opcional, default 3000)
PORT=3000

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,https://newremis-1.onrender.com
